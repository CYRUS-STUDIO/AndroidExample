<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AndroidExample" parent="Theme.AppCompat.NoActionBar">
        <!-- 其他主题属性 -->
        <item name="android:buttonStyle">@style/ButtonStyle</item>
    </style>

    <style name="ButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- 类别标题样式 -->
    <style name="SectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 网格容器样式 -->
    <style name="CategoryGrid">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:columnCount">2</item>
        <item name="android:alignmentMode">alignMargins</item>
    </style>

    <!-- 网格按钮样式 -->
    <style name="GridButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>